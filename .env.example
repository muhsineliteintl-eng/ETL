# PostgreSQL Database (Neon)
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=ml_default
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Secret for Admin Authentication (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin Credentials
ADMIN_USERNAME=admin
# Generate password hash with bcrypt (rounds=12)
# Default password "admin123" hash shown below - CHANGE IN PRODUCTION!
ADMIN_PASSWORD_HASH="$2a$12$WBg6Dn4Y0eatDnXO.OfpIOO9CNtQsg8hRRje2wQIc9eTmeRX6kp7q"

# Email Configuration
ADMIN_EMAIL=your-email@gmail.com
HR_EMAIL=hr-email@gmail.com
EMAIL_FROM_NAME="Elite International Website"

# SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Use Gmail App Password (not regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-16-char-app-password
